# ── Anthropic ────────────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# ── Credenciais padrão para URLs autenticadas (opcional) ──────────────────────
# Usadas quando o usuário NÃO preencher os campos na interface
# Se não quiser usar padrão, deixe em branco — o usuário preencherá manualmente
AUTH_DEFAULT_USERNAME=
AUTH_DEFAULT_PASSWORD=
